# Server Configuration
PORT=3000
NODE_ENV=development

# Turso Database Configuration
TURSO_DATABASE_URL=file:./dev.db
TURSO_AUTH_TOKEN=""

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# AI Coach Configuration
SCITELY_API_KEY=your-scitely-api-key
SCITELY_BASE_URL=https://api.scitely.com/v1
SCITELY_MODEL=qwen3-max

# Frontend URL
FRONTEND_URL=http://localhost:5173

# CORS Origin (comma-separated for multiple domains in production)
CORS_ORIGIN=https://your-frontend-domain.com

# Email / SMTP Configuration
EMAIL_FROM="Nature Meds <no-reply@naturemeds.local>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
